# Your Google Gemini API key.
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) Override the default Gemini model.
# GEMINI_MODEL=gemini-1.5-flash
